# ---------------------------------------------------------------------------
# Pittsburgh Insurance Hub — environment configuration
# Copy this file to `.env.local` and fill in the values you have.
# The site works fully WITHOUT any of these set (safe defaults are used),
# but setting them unlocks live email/LLM features.
# ---------------------------------------------------------------------------

# Public canonical URL of the deployed site (used for SEO / sitemap / schema)
NEXT_PUBLIC_SITE_URL=https://www.pittsburghinsurancehub.com

# Public phone number shown across the site (click-to-call).
NEXT_PUBLIC_BUSINESS_PHONE=(412) 952-4046
# Public, non-personal business email shown on the site. This is NOT where
# leads go — it's just a generic inbox visitors can see.
NEXT_PUBLIC_BUSINESS_EMAIL=quotes@pittsburghinsurancehub.com

# ---- AI Concierge (optional) ----------------------------------------------
# If set, the chat concierge uses an OpenAI-compatible model for richer answers.
# If left blank, a built-in Pittsburgh insurance knowledge base answers instead
# (no key required, still fully functional).
OPENAI_API_KEY=
# Optional overrides:
OPENAI_MODEL=gpt-4o-mini
OPENAI_BASE_URL=https://api.openai.com/v1

# ---- Lead delivery --------------------------------------------------------
# Quote submissions are emailed to LEADS_NOTIFY_EMAIL (this is PRIVATE — it is
# never displayed on the site). It defaults to the value in src/lib/site.ts.
#
# To actually receive lead emails in production you need a RESEND_API_KEY:
#   1. Create a free account at https://resend.com using the email you want
#      leads sent to (johnc.pelusi@gmail.com).
#   2. Create an API key and paste it below (or in Vercel env vars).
#   3. That's it — leads arrive from onboarding@resend.dev with no domain setup.
# Without a key, leads are saved to ./data/leads.jsonl (local dev only).
RESEND_API_KEY=
LEADS_NOTIFY_EMAIL=johnc.pelusi@gmail.com
# Optional: custom verified "from" address once you set up a domain in Resend.
LEADS_FROM_EMAIL=
