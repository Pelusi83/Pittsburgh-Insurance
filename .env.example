# ---------------------------------------------------------------------------
# Pittsburgh Insurance Hub — environment configuration
# Copy this file to `.env.local` and fill in the values you have.
# The site works fully WITHOUT any of these set (safe defaults are used),
# but setting them unlocks live email/LLM features.
# ---------------------------------------------------------------------------

# Public canonical URL of the deployed site (used for SEO / sitemap / schema)
NEXT_PUBLIC_SITE_URL=https://www.pittsburghinsurancehub.com

# Business contact details (shown on the site + used for lead notifications)
NEXT_PUBLIC_BUSINESS_PHONE=(412) 555-0199
NEXT_PUBLIC_BUSINESS_EMAIL=quotes@pittsburghinsurancehub.com

# ---- AI Concierge (optional) ----------------------------------------------
# If set, the chat concierge uses an OpenAI-compatible model for richer answers.
# If left blank, a built-in Pittsburgh insurance knowledge base answers instead
# (no key required, still fully functional).
OPENAI_API_KEY=
# Optional overrides:
OPENAI_MODEL=gpt-4o-mini
OPENAI_BASE_URL=https://api.openai.com/v1

# ---- Lead delivery (optional) ---------------------------------------------
# Where new leads should be emailed. If a Resend key is present, leads are
# emailed; otherwise they are appended to ./data/leads.jsonl for local review.
RESEND_API_KEY=
LEADS_NOTIFY_EMAIL=quotes@pittsburghinsurancehub.com
